{
  "expo": {
    "name": "Traxettle app - by Karkhanis Labs",
    "slug": "traxettle",
    "scheme": "com.traxettle.app",
    "version": "1.0.33",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#6366f1",
      "image": "./assets/splash.png",
      "resizeMode": "cover"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.traxettle.app",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Traxettle uses your photo library so you can upload payment proof images for settlements.",
        "NSPhotoLibraryAddUsageDescription": "Traxettle may save generated proof or receipt images to your photo library when requested.",
        "NSCameraUsageDescription": "Traxettle uses your camera so you can capture payment proof images.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["com.traxettle.app"]
          },
          {
            "CFBundleURLName": "Google Sign-In (local / traxettle-test)",
            "CFBundleURLSchemes": ["com.googleusercontent.apps.603084161476-j4ht8hs7kk6tqqh273q2ks89udmdc3pe"]
          },
          {
            "CFBundleURLName": "Google Sign-In (staging / traxettle-staging)",
            "CFBundleURLSchemes": ["com.googleusercontent.apps.943648574702-cvgj086ppdcbqgcagrekjs4pekn0q1ok"]
          }
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366f1"
      },
      "package": "com.traxettle.app",
      "intentFilters": [
        {
          "action": "android.intent.action.SEND",
          "data": {
            "mimeType": "image/*"
          },
          "categories": [
            "android.intent.category.DEFAULT"
          ]
        }
      ],
      "softwareKeyboardLayoutMode": "adjustResize"
    },
    "plugins": [
      "./plugins/copy-google-service-plist"
    ],
    "owner": "vkarkhanis",
    "extra": {
      "eas": {
        "projectId": "c54ee544-0b20-4d5a-b8d3-873f4df16602"
      }
    }
  }
}
